{
  "name": "ct-round-5",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run build:contracts && turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "fmt": "oxfmt",
    "smoke-test": "turbo run smoke-test",
    "build:contracts": "bun run --cwd packages/contracts build"
  },
  "devDependencies": {
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.9"
}
